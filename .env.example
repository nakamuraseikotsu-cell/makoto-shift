# ===========================================
# Medical CRM ログイン情報設定ファイル (テンプレート)
# ===========================================
# このファイルをコピーして「.env」という名前で保存し、
# 下記の値をご自身のものに書き換えてください。
#
# 重要: .env ファイルは絶対に他人に共有したりGitにアップしないこと！
# ===========================================

CRM_URL=https://example-crm.com/login
CRM_USERNAME=your_login_id_here
CRM_PASSWORD=your_password_here
